# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node (in case landing-page tooling needs it later)
node_modules/
dist/
build/
.next/
.cache/
.parcel-cache/

# Env and secrets — never commit
.env
.env.local
landing/assets/config.local.js
.env.*.local
*.pem
*.key
secrets/

# Vercel build output (copy of landing/)
dist/

# Customer tracker (PII — local only)
data/customers.json
data/customers-export.csv

# Customer YAML inputs for deliver_report.py — never commit real customer data.
# Example templates (customers/example-*.yaml) are explicitly allowed.
customers/*.yaml
!customers/example-*.yaml

# Tally API responses (form IDs are not secret, but keep local)
data/tally_*.json
output/tally/

# Generated output (scans, screenshots, intermediate artifacts)
output/
!output/.gitkeep
scans/
screenshots/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Cursor / Claude internals
.cursor/
.claude/
