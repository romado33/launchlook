# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node (in case landing-page tooling needs it later)
node_modules/
dist/
build/
.next/
.cache/
.parcel-cache/

# Env and secrets — never commit
.env
.env.local
landing/assets/config.local.js
.env.*.local
*.pem
*.key
secrets/

# Vercel build output (copy of landing/)
dist/

# Customer tracker (PII — local only)
data/customers.json
data/customers-export.csv

# Customer YAML inputs for deliver_report.py — never commit real customer data.
# Example templates (customers/example-*.yaml) are explicitly allowed.
customers/*.yaml
!customers/example-*.yaml

# Tally API responses (form IDs are not secret, but keep local)
data/tally_*.json
output/tally/

# Generated output (scans, screenshots, intermediate artifacts)
output/
!output/.gitkeep
scans/
screenshots/*
!screenshots/.gitkeep

# Audit UI runtime (drafts/<slug>.json, gitignored — local only)
drafts/*
!drafts/.gitkeep

# AI audit feedback data (per-customer)
data/ai_feedback/

# AI cost-tracker log files (per-day JSONL). The `.gitkeep` is tracked
# so the directory exists in a fresh checkout, but per-day logs are
# local-only runtime data.
data/ai_costs/*
!data/ai_costs/.gitkeep

# Accessibility (axe) per-URL response cache; pure runtime, regenerated.
data/axe_cache/

# Form smoke-test per-URL response cache; pure runtime, regenerated.
data/form_smoke_cache/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Cursor / Claude internals
.cursor/
.claude/

# Local-only research and intermediate audit reports
# `bestpractices/` is a scratch folder of saved external articles + asset
# dumps used as research input for prompt + glossary work. Many MB of HTML
# + assets; not part of the shipped product.
bestpractices/
# Worker subagents occasionally drop intermediate verification/shipment
# reports at the repo root or under docs/. They are valuable for the
# author but not for shipping; keep them local-only.
docs/SHIPMENT-VERIFICATION-PARTIAL-2026-05-26.md
# `verify-tmp/` is a re-runnable scratch directory where the verification
# scripts cache live-site HTML snapshots for diffing. Always regenerated.
verify-tmp/
# Worker scratch helpers at repo root (Stripe / Resend / Tally / Notion
# probes and one-shot scripts; loaded from .env, no hardcoded secrets,
# but they shouldn't be in git history either).
/_*.py
/_*.txt
/_*.out
/stripe_created.json
