<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ qsg.title if qsg else title }} · Quick Start Guide</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --paper: #FAF7F2;
      --ink: #1F1B16;
      --muted: #6B6359;
      --accent: {{ primary_color | default('#B45309') }};
      --line: #E7E0D6;
      --surface: #FFFFFF;
      --surface-tint: #F4EFE7;
    }

    @page {
      size: A4 portrait;
      margin: 25mm 20mm 22mm 20mm;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--paper);
      color: var(--ink);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 10.5pt;
      line-height: 1.6;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .doc-header {
      border-top: 3px solid var(--accent);
      padding-top: 10pt;
      margin-bottom: 14pt;
    }

    .eyebrow {
      font-size: 8pt;
      font-weight: 600;
      color: var(--accent);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin: 0;
    }

    h1 {
      font-family: 'Fraunces', Georgia, 'Times New Roman', serif;
      font-weight: 500;
      font-size: 24pt;
      line-height: 1.15;
      margin: 6pt 0 4pt;
      color: var(--ink);
      letter-spacing: -0.005em;
    }

    .subtitle {
      font-size: 10pt;
      color: var(--muted);
      margin: 0;
    }

    .intro {
      margin: 14pt 0 18pt;
      padding: 14pt 16pt;
      background: var(--surface);
      border: 1px solid var(--line);
      border-left: 3px solid var(--accent);
      border-radius: 4pt;
      page-break-inside: avoid;
    }

    .intro p {
      margin: 0;
      font-size: 10.5pt;
      color: var(--ink);
      line-height: 1.6;
      white-space: pre-wrap;
    }

    h2 {
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 500;
      font-size: 14pt;
      margin: 18pt 0 8pt;
      padding-bottom: 4pt;
      border-bottom: 1px solid var(--line);
      page-break-after: avoid;
    }

    .steps {
      margin: 0;
      padding: 0;
      list-style: none;
      counter-reset: stepcount;
    }

    .step {
      counter-increment: stepcount;
      margin: 8pt 0;
      padding: 11pt 14pt 12pt 42pt;
      position: relative;
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 4pt;
      page-break-inside: avoid;
    }

    .step::before {
      content: counter(stepcount);
      position: absolute;
      top: 11pt;
      left: 12pt;
      width: 22pt;
      height: 22pt;
      border-radius: 50%;
      background: var(--accent);
      color: var(--paper);
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      font-size: 10pt;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .step-title {
      margin: 0 0 4pt;
      font-size: 11.5pt;
      font-weight: 600;
      color: var(--ink);
    }

    .step-body {
      margin: 0;
      font-size: 10pt;
      color: var(--muted);
      line-height: 1.6;
      white-space: pre-wrap;
    }

    /* q20: AI-builder deep-link buttons. Gated to Pro Package per
       PRODUCT-DECISIONS.md section 1 ("deep links in QSG" = Pro
       deliverable). Each button is a real PDF hyperlink that opens
       the buyer's AI builder with the step body URL-encoded as the
       chat prompt. */
    .step-actions {
      margin: 10pt 0 0;
      padding-top: 8pt;
      border-top: 1px dashed var(--line);
      display: flex;
      flex-wrap: wrap;
      gap: 6pt;
      align-items: center;
    }

    .step-actions-label {
      font-size: 8.5pt;
      color: var(--muted);
      margin-right: 4pt;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-weight: 600;
    }

    .step-action {
      display: inline-block;
      padding: 4pt 9pt;
      font-size: 8.5pt;
      font-weight: 600;
      font-family: 'Inter', sans-serif;
      color: var(--surface);
      background: var(--accent);
      border-radius: 999pt;
      text-decoration: none;
      letter-spacing: 0.01em;
    }

    .step-action.secondary {
      color: var(--ink);
      background: var(--surface-tint);
      border: 1px solid var(--line);
    }

    .step-copy {
      display: inline-block;
      padding: 4pt 9pt;
      font-size: 8.5pt;
      font-weight: 600;
      color: var(--muted);
      background: transparent;
      border: 1px dashed var(--line);
      border-radius: 999pt;
      font-family: 'Inter', sans-serif;
    }

    .pro-appendix {
      margin: 22pt 0 8pt;
      padding: 12pt 14pt;
      background: var(--surface);
      border: 1px solid var(--line);
      border-left: 3px solid var(--accent);
      border-radius: 4pt;
      page-break-inside: avoid;
    }

    .pro-appendix h3 {
      margin: 0 0 6pt;
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 500;
      font-size: 11.5pt;
      color: var(--ink);
    }

    .pro-appendix ol {
      margin: 0;
      padding-left: 18pt;
      font-size: 9.5pt;
      color: var(--muted);
      line-height: 1.55;
    }

    .footer-note {
      margin-top: 18pt;
      padding: 10pt 12pt;
      border: 1px dashed var(--line);
      border-radius: 4pt;
      background: var(--surface-tint);
      font-size: 9.5pt;
      color: var(--muted);
      page-break-inside: avoid;
      white-space: pre-wrap;
    }

    .closing {
      margin-top: 22pt;
      padding-top: 10pt;
      border-top: 1px solid var(--line);
      font-size: 9pt;
      color: var(--muted);
    }

    /* Legacy body_html rendering (kept for back-compat with qsg_render.py) */
    .legacy-body p, .legacy-body li {
      color: var(--muted);
      font-size: 10pt;
      line-height: 1.6;
    }
    .legacy-body strong { color: var(--ink); }
    .legacy-body h2 {
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 500;
      font-size: 14pt;
    }
    .legacy-body ol, .legacy-body ul { padding-left: 1.25rem; }
    .legacy-body a { color: var(--accent); }
    .reviewer {
      background: #FEF3C7;
      border-left: 3px solid var(--accent);
      padding: 6pt 10pt;
      margin: 8pt 0;
      font-size: 9.5pt;
    }
  </style>
</head>
<body>

  {#-
    q20: AI-builder deep-link helpers.

    We never market these on landing pages (per SIMPLICITY-GUARDRAILS
    section 6); they live only inside delivered QSG PDFs. Each button
    is a real PDF hyperlink that opens the buyer's AI builder with
    the step body URL-encoded as the chat prompt. Buttons render only
    at the Pro Package tier per PRODUCT-DECISIONS.md section 1; the
    plain-text body above each button is always copy-pasteable.
  -#}
  {%- set _tier = customer.tier if customer and customer.tier else "" %}
  {%- set _builder = (customer.builder if customer and customer.builder else "") | lower %}
  {%- set _show_deep_links = (_tier == "Pro Package") %}

  {% if qsg %}
    <header class="doc-header">
      <p class="eyebrow">
        LaunchLook · Quick Start Guide
        {%- if customer and customer.tier %} · {{ customer.tier }}{% endif %}
      </p>
      <h1>{{ qsg.title }}</h1>
      <p class="subtitle">
        For first-time users of
        {%- if customer %} {{ customer.app_name }}{% else %} the app{% endif %}
        · prepared {{ delivered_at | default(generated_date) }}
      </p>
    </header>

    {% if qsg.intro %}
    <section class="intro">
      <p>{{ qsg.intro }}</p>
    </section>
    {% endif %}

    {% if qsg.steps %}
    <h2>Get started</h2>
    <ol class="steps">
      {% for step in qsg.steps %}
      {%- set _encoded = step.body | string | urlencode %}
      <li class="step">
        <p class="step-title">{{ step.title }}</p>
        <p class="step-body">{{ step.body }}</p>

        {% if _show_deep_links %}
        <div class="step-actions">
          <span class="step-actions-label">Open this in your AI builder:</span>

          {%- if _builder == "lovable" %}
            <a class="step-action" href="https://lovable.dev/">Open in Lovable</a>
          {%- endif %}

          <a class="step-action{% if _builder != 'bolt' %} secondary{% endif %}"
             href="https://bolt.new/?q={{ _encoded }}">Open in Bolt</a>

          <a class="step-action{% if _builder != 'v0' %} secondary{% endif %}"
             href="https://v0.app/chat?q={{ _encoded }}">Open in v0</a>

          <a class="step-action{% if _builder != 'cursor' %} secondary{% endif %}"
             href="cursor://anysphere.cursor-deeplink/prompt?text={{ _encoded }}">Open in Cursor</a>

          {%- if _builder == "webflow" %}
            <a class="step-action" href="https://webflow.com/dashboard">Open Webflow Designer</a>
          {%- endif %}

          <span class="step-copy" aria-label="Or copy the text above and paste it manually">Copy</span>
        </div>
        {% endif %}
      </li>
      {% endfor %}
    </ol>
    {% endif %}

    {% if _show_deep_links and qsg.steps %}
    <section class="pro-appendix">
      <h3>How to apply these prompts in one pass</h3>
      <ol>
        {%- if _builder == "cursor" %}
        <li>Open your project in Cursor.</li>
        <li>Click each "Open in Cursor" button below in order. The prompt loads into the chat panel.</li>
        <li>After each prompt, run your local dev server and verify the change in the browser.</li>
        <li>Commit each fix as you go so you can roll back one step at a time.</li>
        {%- elif _builder == "lovable" %}
        <li>Open your project in Lovable.</li>
        <li>Select the text above each "Copy" pill, copy it, and paste it into the Lovable chat.</li>
        <li>After each AI reply, click "Preview" to confirm the change before moving on.</li>
        {%- elif _builder == "bolt" %}
        <li>Open your project in Bolt.</li>
        <li>Click each "Open in Bolt" button below in order; each one loads a prompt into a fresh chat.</li>
        <li>Apply the diff Bolt suggests, then run the dev preview before moving on.</li>
        {%- elif _builder == "v0" %}
        <li>Open v0.app and sign into your project.</li>
        <li>Click each "Open in v0" button below in order; each one drops the prompt into a new chat.</li>
        <li>Apply the component diff, preview, then move on.</li>
        {%- elif _builder == "webflow" %}
        <li>Open Webflow Designer for your site.</li>
        <li>The prompts above describe what to change in the Designer. Apply one prompt per session, then publish.</li>
        <li>Re-test the published URL after each publish before moving on.</li>
        {%- else %}
        <li>Pick the builder you use most. Click the matching "Open in" button on each step.</li>
        <li>Apply one prompt at a time. Run the live preview before moving to the next.</li>
        <li>Commit each fix separately so you can roll back one step at a time.</li>
        {%- endif %}
      </ol>
    </section>
    {% endif %}

    {% if qsg.footer_note %}
    <p class="footer-note">{{ qsg.footer_note }}</p>
    {% endif %}

    <p class="closing">
      Quick Start Guide prepared by LaunchLook
      {%- if delivered_at %} · {{ delivered_at }}{% elif generated_date %} · {{ generated_date }}{% endif %}
    </p>

  {% else %}
    {# Legacy mode: qsg_render.py passes body_html derived from Markdown. #}
    <header class="doc-header">
      <p class="eyebrow">LaunchLook · Quick Start Guide</p>
      <h1>{{ title }}</h1>
    </header>
    <div class="legacy-body">
      {{ body_html | safe }}
    </div>
    <p class="closing">Quick Start Guide prepared by LaunchLook · {{ generated_date }}</p>
  {% endif %}

</body>
</html>
