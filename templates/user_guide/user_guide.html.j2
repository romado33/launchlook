<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ user_guide.title if user_guide else title }} · User Guide</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --paper: #FAF7F2;
      --ink: #1F1B16;
      --muted: #6B6359;
      --accent: {{ primary_color | default('#B45309') }};
      --line: #E7E0D6;
      --surface: #FFFFFF;
      --surface-tint: #F4EFE7;
    }

    @page {
      size: A4 portrait;
      margin: 25mm 20mm 22mm 20mm;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--paper);
      color: var(--ink);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 10.5pt;
      line-height: 1.6;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .doc-header {
      border-top: 3px solid var(--accent);
      padding-top: 10pt;
      margin-bottom: 14pt;
    }

    .eyebrow {
      font-size: 8pt;
      font-weight: 600;
      color: var(--accent);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin: 0;
    }

    h1 {
      font-family: 'Fraunces', Georgia, 'Times New Roman', serif;
      font-weight: 500;
      font-size: 22pt;
      line-height: 1.15;
      margin: 6pt 0 4pt;
      color: var(--ink);
      letter-spacing: -0.005em;
    }

    .subtitle {
      font-size: 10pt;
      color: var(--muted);
      margin: 0;
    }

    .intro {
      margin: 14pt 0 18pt;
      padding: 14pt 16pt;
      background: var(--surface);
      border: 1px solid var(--line);
      border-left: 3px solid var(--accent);
      border-radius: 4pt;
      page-break-inside: avoid;
    }

    .intro p {
      margin: 0;
      font-size: 10.5pt;
      color: var(--ink);
      line-height: 1.6;
      white-space: pre-wrap;
    }

    /* Section heading */
    h2 {
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 500;
      font-size: 13pt;
      margin: 18pt 0 8pt;
      padding-bottom: 4pt;
      border-bottom: 1px solid var(--line);
      page-break-after: avoid;
      color: var(--ink);
    }

    /* Steps within a section */
    .steps {
      margin: 0 0 4pt;
      padding: 0;
      list-style: none;
      counter-reset: stepcount;
    }

    .step {
      counter-increment: stepcount;
      margin: 6pt 0;
      padding: 10pt 13pt 11pt 40pt;
      position: relative;
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 4pt;
      page-break-inside: avoid;
    }

    .step::before {
      content: counter(stepcount);
      position: absolute;
      top: 10pt;
      left: 11pt;
      width: 20pt;
      height: 20pt;
      border-radius: 50%;
      background: var(--accent);
      color: var(--paper);
      font-family: 'Inter', sans-serif;
      font-weight: 600;
      font-size: 9pt;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .step-title {
      margin: 0 0 3pt;
      font-size: 11pt;
      font-weight: 600;
      color: var(--ink);
    }

    .step-body {
      margin: 0;
      font-size: 10pt;
      color: var(--muted);
      line-height: 1.6;
      white-space: pre-wrap;
    }

    /* FAQ section */
    .faq-section {
      margin-top: 18pt;
    }

    .faq-item {
      margin: 0 0 10pt;
      padding: 10pt 13pt;
      background: var(--surface-tint);
      border: 1px solid var(--line);
      border-radius: 4pt;
      page-break-inside: avoid;
    }

    .faq-q {
      margin: 0 0 4pt;
      font-size: 10.5pt;
      font-weight: 600;
      color: var(--ink);
    }

    .faq-a {
      margin: 0;
      font-size: 10pt;
      color: var(--muted);
      line-height: 1.6;
      white-space: pre-wrap;
    }

    .footer-note {
      margin-top: 18pt;
      padding: 10pt 12pt;
      border: 1px dashed var(--line);
      border-radius: 4pt;
      background: var(--surface);
      font-size: 9.5pt;
      color: var(--muted);
      page-break-inside: avoid;
      white-space: pre-wrap;
    }

    .closing {
      margin-top: 22pt;
      padding-top: 10pt;
      border-top: 1px solid var(--line);
      font-size: 9pt;
      color: var(--muted);
    }

    /* Counter resets per section so step numbers restart */
    .section-block .steps {
      counter-reset: stepcount;
    }
  </style>
</head>
<body>

  {% if user_guide %}
    <header class="doc-header">
      <p class="eyebrow">
        {{ customer.app_name if customer else 'User Guide' }}
        {%- if customer and customer.tier %} · {{ customer.tier }}{% endif %}
      </p>
      <h1>{{ user_guide.title }}</h1>
      <p class="subtitle">
        User Guide · prepared {{ delivered_at | default(generated_date) }}
      </p>
    </header>

    {% if user_guide.intro %}
    <section class="intro">
      <p>{{ user_guide.intro }}</p>
    </section>
    {% endif %}

    {% for section in user_guide.sections %}
    <div class="section-block">
      <h2>{{ section.heading }}</h2>
      {% if section.steps %}
      <ol class="steps">
        {% for step in section.steps %}
        <li class="step">
          <p class="step-title">{{ step.title }}</p>
          <p class="step-body">{{ step.body }}</p>
        </li>
        {% endfor %}
      </ol>
      {% endif %}
    </div>
    {% endfor %}

    {% if user_guide.faq %}
    <div class="faq-section">
      <h2>Common questions</h2>
      {% for entry in user_guide.faq %}
      <div class="faq-item">
        <p class="faq-q">{{ entry.question }}</p>
        <p class="faq-a">{{ entry.answer }}</p>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% if user_guide.footer_note %}
    <p class="footer-note">{{ user_guide.footer_note }}</p>
    {% endif %}

    <p class="closing">
      User Guide prepared by {{ customer.app_name if customer else 'the app' }}
      {%- if delivered_at %} · {{ delivered_at }}{% elif generated_date %} · {{ generated_date }}{% endif %}
    </p>

  {% endif %}

</body>
</html>
