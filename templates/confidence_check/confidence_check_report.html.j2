<!DOCTYPE html>
{# ----------------------------------------------------------------------
   Confidence Check / Saboteur re-scan — short-form report.

   Modeled on templates/report/report.html.j2, trimmed to:
     - Header ("Confidence Check by The Saboteur" + verdict label)
     - "What's now fixed" (✓)
     - "Still showing up" (✗)
     - "New things that surfaced" (⚠ regressions)
     - Footer ("Need another? Send in The Saboteur again.")

   Voice: The Saboteur (per docs/TESTERS-CAST.md §6). Mischievous,
   conversational, "chaos monkey trying to break things." NOT QA-report
   style. Per SIMPLICITY-GUARDRAILS §3.4.
---------------------------------------------------------------------- #}
{% set check = confidence_check %}
{% set page_title = check.app_name ~ ' · LaunchLook Confidence Check' %}
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ page_title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --paper: #FAF7F2;
      --ink: #1F1B16;
      --muted: #6B6359;
      --accent: #B45309;
      --line: #E7E0D6;
      --surface: #FFFFFF;
      --surface-tint: #F4EFE7;
      --critical: #B91C1C;
      --high: #C2410C;
      --medium: #B45309;
      --low: #15803D;
    }

    @page {
      size: A4 portrait;
      margin: 25mm 20mm 22mm 20mm;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--paper);
      color: var(--ink);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 10.5pt;
      line-height: 1.55;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .doc-header {
      border-top: 3px solid var(--accent);
      padding-top: 10pt;
      margin-bottom: 14pt;
    }

    .eyebrow {
      font-size: 8pt;
      font-weight: 600;
      color: var(--accent);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin: 0;
    }

    h1 {
      font-family: 'Fraunces', Georgia, 'Times New Roman', serif;
      font-weight: 500;
      font-size: 26pt;
      line-height: 1.15;
      margin: 6pt 0 4pt;
      color: var(--ink);
      letter-spacing: -0.005em;
    }

    .subtitle {
      font-size: 10pt;
      color: var(--muted);
      margin: 0 0 6pt;
    }

    .subtitle code {
      font-family: 'JetBrains Mono', Consolas, monospace;
      font-size: 9pt;
      background: var(--surface-tint);
      padding: 1pt 4pt;
      border-radius: 3pt;
      color: var(--ink);
    }

    .verdict {
      margin: 14pt 0 18pt;
      padding: 14pt 16pt;
      background: var(--surface);
      border: 1px solid var(--line);
      border-left: 3px solid var(--accent);
      border-radius: 4pt;
      page-break-inside: avoid;
    }

    .verdict-label {
      font-size: 8pt;
      font-weight: 600;
      color: var(--accent);
      letter-spacing: 0.16em;
      text-transform: uppercase;
      margin: 0 0 4pt;
    }

    .verdict-summary {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 14pt;
      line-height: 1.3;
      margin: 0 0 4pt;
      color: var(--ink);
      font-weight: 500;
    }

    .verdict-emoji {
      margin-right: 4pt;
      font-size: 13pt;
    }

    .verdict-tagline {
      font-size: 10.5pt;
      color: var(--muted);
      line-height: 1.5;
      margin: 0 0 8pt;
    }

    .verdict-narrative {
      font-size: 10pt;
      color: var(--muted);
      line-height: 1.6;
      margin: 0;
      white-space: pre-wrap;
    }

    h2.section {
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 500;
      font-size: 16pt;
      margin: 18pt 0 8pt;
      padding-bottom: 4pt;
      border-bottom: 1px solid var(--line);
      page-break-after: avoid;
    }

    h2.section .count {
      font-family: 'Inter', sans-serif;
      font-size: 9pt;
      color: var(--muted);
      font-weight: 400;
      margin-left: 6pt;
    }

    .item-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .item {
      padding: 8pt 12pt;
      margin: 6pt 0;
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 4pt;
      page-break-inside: avoid;
    }

    .item.fixed       { border-left: 3px solid var(--low); }
    .item.still       { border-left: 3px solid var(--high); }
    .item.new         { border-left: 3px solid var(--medium); }

    .item-title {
      font-size: 11pt;
      font-weight: 600;
      color: var(--ink);
      margin: 0 0 3pt;
      line-height: 1.35;
    }

    .item-note {
      font-size: 10pt;
      color: var(--muted);
      line-height: 1.55;
      margin: 0;
    }

    .item-note .marker {
      font-weight: 600;
      margin-right: 4pt;
    }

    .item.fixed .item-note .marker { color: var(--low); }
    .item.still .item-note .marker { color: var(--high); }
    .item.new   .item-note .marker { color: var(--medium); }

    .empty-note {
      font-size: 10pt;
      color: var(--muted);
      font-style: italic;
      margin: 4pt 0 0;
    }

    .closing {
      margin-top: 22pt;
      padding-top: 12pt;
      border-top: 1px solid var(--line);
      font-size: 10pt;
      color: var(--muted);
      line-height: 1.6;
      page-break-inside: avoid;
    }

    .closing strong { color: var(--ink); font-weight: 500; }
  </style>
</head>
<body>
  <div class="page">

    <header class="doc-header">
      <p class="eyebrow">Confidence Check by The Saboteur</p>
      <h1>{{ check.app_name or 'Confidence Check' }}</h1>
      <p class="subtitle">
        Re-scan after fixes
        {%- if check.customer_first_name %} for {{ check.customer_first_name }}{% endif -%}
        {%- if check.url %} · <code>{{ check.url }}</code>{% endif -%}
        {%- if delivered_at %} · prepared {{ delivered_at }}{% endif -%}
      </p>
    </header>

    <section class="verdict">
      <p class="verdict-label">Verdict</p>
      <p class="verdict-summary">
        <span class="verdict-emoji" aria-hidden="true">{{ verdict.emoji }}</span>
        {{ verdict.label }}
      </p>
      {% if verdict.summary %}
      <p class="verdict-tagline">{{ verdict.summary }}</p>
      {% endif %}
      {% if verdict.narrative %}
      <p class="verdict-narrative">{{ verdict.narrative }}</p>
      {% endif %}
    </section>

    <h2 class="section">
      What's now fixed
      <span class="count">({{ fixed|length }})</span>
    </h2>
    {% if fixed %}
    <ul class="item-list">
      {% for f in fixed %}
      <li class="item fixed">
        <p class="item-title">{{ f.original_title }}</p>
        <p class="item-note"><span class="marker">✓</span>{{ f.saboteur_note }}</p>
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="empty-note">Nothing crossed off yet. The original findings are still in play.</p>
    {% endif %}

    <h2 class="section">
      Still showing up
      <span class="count">({{ still_present|length }})</span>
    </h2>
    {% if still_present %}
    <ul class="item-list">
      {% for s in still_present %}
      <li class="item still">
        <p class="item-title">{{ s.original_title }}</p>
        <p class="item-note"><span class="marker">✗</span>{{ s.saboteur_note }}</p>
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="empty-note">None. Every previous finding looks resolved.</p>
    {% endif %}

    <h2 class="section">
      New things that surfaced
      <span class="count">({{ new|length }})</span>
    </h2>
    {% if new %}
    <ul class="item-list">
      {% for n in new %}
      <li class="item new">
        <p class="item-title">{{ n.title }}</p>
        <p class="item-note"><span class="marker">⚠</span>{{ n.saboteur_note }}</p>
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="empty-note">Nothing new turned up. Clean re-walk.</p>
    {% endif %}

    <section class="closing">
      <p>
        <strong>Need another?</strong>
        {{ footer_note or 'Send in The Saboteur again whenever you ship the next round.' }}
      </p>
    </section>

  </div>
</body>
</html>
