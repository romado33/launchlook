{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/copy-landing-for-vercel.mjs",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/**/*.py": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/ai.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/:path*.md",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/.well-known/agent-resources.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self' mailto: https://buy.stripe.com https://link.stripe.com https://tally.so https://*.tally.so; upgrade-insecure-requests" }
      ]
    }
  ],
  "redirects": [
    { "source": "/assets/config.local.js", "destination": "/404", "statusCode": 404 },
    { "source": "/.env", "destination": "/404", "statusCode": 404 },
    { "source": "/.env.local", "destination": "/404", "statusCode": 404 },
    { "source": "/sample", "destination": "/r/jane-sparkle-marketplace.html", "permanent": true },
    { "source": "/sample.html", "destination": "/r/jane-sparkle-marketplace.html", "permanent": true },
    { "source": "/checklist", "destination": "/", "permanent": true },
    { "source": "/checklist.html", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/thanks", "destination": "/thanks.html" },
    { "source": "/thanks-free-audit", "destination": "/thanks-free-audit.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/webflow", "destination": "/webflow.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/e2e", "destination": "/e2e.html" }
  ]
}
