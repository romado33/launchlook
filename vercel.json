{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/copy-landing-for-vercel.mjs",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/**/*.py": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://cdn.tailwindcss.com https://plausible.io; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://plausible.io; frame-ancestors 'none'; base-uri 'self'; form-action 'self' mailto: https://buy.stripe.com https://link.stripe.com https://tally.so https://*.tally.so; upgrade-insecure-requests" }
      ]
    }
  ],
  "redirects": [
    { "source": "/assets/config.local.js", "destination": "/404", "statusCode": 404 },
    { "source": "/.env", "destination": "/404", "statusCode": 404 },
    { "source": "/.env.local", "destination": "/404", "statusCode": 404 }
  ],
  "rewrites": [
    { "source": "/checklist", "destination": "/checklist.html" },
    { "source": "/thanks", "destination": "/thanks.html" },
    { "source": "/sample", "destination": "/sample.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/webflow", "destination": "/webflow.html" },
    { "source": "/verify", "destination": "/verify.html" },
    { "source": "/verify-scope", "destination": "/verify-scope.html" },
    { "source": "/r/:slug", "destination": "/r.html?slug=:slug" }
  ]
}
