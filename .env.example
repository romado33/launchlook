# LaunchLook — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# ---------------------------------------------------------------------------
# Domain
# ---------------------------------------------------------------------------
LAUNCHLOOK_DOMAIN=launchlook.app
FROM_EMAIL=hello@launchlook.app
ADMIN_EMAIL=rob@launchlook.app
# Aliases that forward to the same inbox (configure in ImprovMX):
#   support@launchlook.app  →  romado33@gmail.com

# ---------------------------------------------------------------------------
# Notion (BL-03, BL-04)
# ---------------------------------------------------------------------------
# Create an integration at https://www.notion.so/profile/integrations,
# then share each database with the integration from the Notion UI.
NOTION_TOKEN=
NOTION_CUSTOMERS_DB_ID=
NOTION_FINDINGS_DB_ID=
NOTION_OUTREACH_DB_ID=
NOTION_REPORTS_PARENT_PAGE_ID=
NOTION_CRAWLER_WISHLIST_PAGE_ID=
# Free 3-finding audit requests (api/free-audit.py). Used for rate limits,
# duplicate detection, and Starter dedup. See docs/FREE-AUDIT-WORKFLOW.md
# for the DB schema (Email / URL / IP / Status / Source / Platform /
# Finding Fingerprints) and the daily intake routine.
NOTION_FREE_AUDIT_DB_ID=

# ---------------------------------------------------------------------------
# Stripe (BL-02, BL-12)
# ---------------------------------------------------------------------------
# Start in test mode until ready to go live (Stripe Dashboard → Developers → API keys).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Payment link URLs (filled in from Stripe Dashboard once products exist).
# After the May 2026 price bump:
#   STARTER → $19 (was $9)
#   LAUNCH  → Full Package $49 (was $29)
#   PRO     → $99 (NEW — see docs/MANUAL-TASKS-PRICE-BUMP.md)
STRIPE_PAYMENT_LINK_STARTER=
STRIPE_PAYMENT_LINK_LAUNCH=
STRIPE_PAYMENT_LINK_PRO=
# Legacy names (optional): QUICK_CHECKUP → starter, LAUNCH_PACK → launch
STRIPE_PAYMENT_LINK_QUICK_CHECKUP=
STRIPE_PAYMENT_LINK_LAUNCH_PACK=

# ---------------------------------------------------------------------------
# Email — Resend (BL-13)
# ---------------------------------------------------------------------------
# Used by scripts/deliver_report.py (Main Report + QSG PDFs as attachments)
# and scripts/followup_send.py. Get a key at https://resend.com/api-keys.
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Tally (intake form creation/management via API)
# ---------------------------------------------------------------------------
# Settings → API keys → Create API key. Format: tly-xxxx...
# Used by scripts/tally_create_intake.py.
TALLY_API_KEY=

# ---------------------------------------------------------------------------
# AI — Quick Start Guide pipeline (BL-09)
# ---------------------------------------------------------------------------
# Default workflow is MANUAL: paste the rendered user message into chatgpt.com.
# These keys are only needed if/when you wire up API automation later.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Playwright (BL-14 — gated on customer 10)
# ---------------------------------------------------------------------------
HEADLESS=true

# ---------------------------------------------------------------------------
# PageSpeed Insights (q14: performance & speed finding category)
# ---------------------------------------------------------------------------
# Optional. PSI works without a key but is rate-limited (25 req/100s
# anonymous, shared). With a key the quota is 25,000 requests/day per
# project. Get a free key at
# https://developers.google.com/speed/docs/insights/v5/get-started.
#
# Responses are cached for 24h per URL in data/psi_cache/ (gitignored)
# so re-runs of the same pipeline do not burn the quota.
PSI_API_KEY=
# PAGESPEED_API_KEY is accepted as an alias for older configs.
