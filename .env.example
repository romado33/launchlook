# LaunchLook — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
#
# For Vercel: paste each non-empty value into Project Settings → Environment
# Variables. Mark all keys as "Production, Preview, Development" unless
# otherwise noted in the comment above the variable.

# ---------------------------------------------------------------------------
# Domain + identity
# ---------------------------------------------------------------------------
LAUNCHLOOK_DOMAIN=launchlook.app
FROM_EMAIL=hello@launchlook.app
ADMIN_EMAIL=rob@launchlook.app
# Both addresses above are sending-only on the Resend side. To actually
# receive mail at *@launchlook.app, set up Cloudflare Email Routing
# (catch-all -> romado33@gmail.com) or ImprovMX. Update Resend suppression
# list after the catch-all is live so bounced addresses can send again.

# ---------------------------------------------------------------------------
# Notion (BL-03, BL-04)
# ---------------------------------------------------------------------------
# Create an integration at https://www.notion.so/profile/integrations,
# then share each database with the integration from the Notion UI.
NOTION_TOKEN=

# Customers DB — paid customer records, intake state, follow-up tracking.
# Used by: api/stripe-webhook.py, api/tally-webhook.py, scripts/dashboard.py,
# scripts/referral_create.py.
NOTION_CUSTOMERS_DB_ID=

# Findings Library DB — catalog of finding templates (38 rows). Read by the
# offline audit pipeline when generating reports.
NOTION_FINDINGS_DB_ID=

# Outreach Tracker DB — cold-outreach pipeline state.
NOTION_OUTREACH_DB_ID=

# Free Audit Requests DB — receives every /api/free-audit submission. Required
# for the hero free 3-finding audit form to work. Schema documented in
# docs/FREE-AUDIT-WORKFLOW.md section 4 + api/free-audit.py lines 200-211.
# Properties: Request (title), Email (email), URL (url), IP (rich_text),
# Status (select: queued/processed/delivered/skipped/abuse), Source (select:
# index/webflow/api), Platform (select: vibe-coder/webflow), Finding
# Fingerprints (rich_text).
NOTION_FREE_AUDIT_DB_ID=

# Confidence Check (Saboteur re-scan) deliveries DB. Used by
# api/stripe-webhook.py when a $19 / $9 Confidence Check payment lands.
# If unset, the webhook logs a warning and skips the Notion write but the
# add-on still emails the customer. Schema docs are in
# docs/CONFIDENCE-CHECK-WORKFLOW.md.
NOTION_CONFIDENCE_CHECK_DB_ID=

# Parent page that hosts per-customer report sub-pages. Used by report
# rendering scripts. Not a DB — a regular Notion page ID.
NOTION_REPORTS_PARENT_PAGE_ID=

# Crawler wishlist page — vestigial; safe to leave blank unless you turn on
# the crawler feature (currently deferred per docs/PRODUCT-DECISIONS.md).
NOTION_CRAWLER_WISHLIST_PAGE_ID=

# ---------------------------------------------------------------------------
# Stripe (BL-02, BL-12)
# ---------------------------------------------------------------------------
# LIVE mode keys at Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=

# Set after registering the webhook endpoint at Stripe Dashboard → Developers
# → Webhooks → "+ Add endpoint" with URL https://launchlook.app/api/stripe-webhook
# and event checkout.session.completed. Required for paid checkouts to trigger
# the downstream pipeline (Notion row creation, welcome email, intake link).
# Without this, every paid checkout completes on Stripe's side but nothing
# downstream fires.
STRIPE_WEBHOOK_SECRET=

# Note: customer-facing Payment Link URLs (Starter $19 / Scale Up $49 /
# Pro $99 / Saboteur $19 + $9 / Handoff $49 / Verified re-verify $9) are
# NOT secrets. They live in landing/assets/config.js and are read at runtime
# by apply-config.js. Do not put them here.

# ---------------------------------------------------------------------------
# Email — Resend (BL-13)
# ---------------------------------------------------------------------------
# Used by scripts/deliver_report.py (Main Report + QSG + Pre-Launch Checklist
# PDFs as attachments), api/free-audit.py, api/stripe-webhook.py.
# Get a key at https://resend.com/api-keys. Domain launchlook.app must be
# verified for sending (already done).
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Tally
# ---------------------------------------------------------------------------
# Tally API key for scripts/tally_create_intake.py. Settings → API keys →
# Create API key. Format: tly-xxxx...
TALLY_API_KEY=

# Shared secret for verifying inbound Tally webhooks. Generate any random
# string (e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`),
# then configure the Tally form QKOX1A → Integrations → Webhooks with URL
# https://launchlook.app/api/tally-webhook?t=<this-token>. Without this, the
# intake webhook returns 401 and intake answers never reach Notion.
TALLY_WEBHOOK_TOKEN=

# Password for the internal go-live checklist at https://launchlook.app/e2e
# (POST /api/e2e-auth). Generate: python -c "import secrets; print(secrets.token_urlsafe(24))"
E2E_CHECKLIST_PASSWORD=

# ---------------------------------------------------------------------------
# AI — Quick Start Guide pipeline (BL-09)
# ---------------------------------------------------------------------------
# Default workflow is MANUAL: paste the rendered user message into chatgpt.com.
# These keys are only needed if/when you wire up API automation later.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Google PageSpeed Insights (q14 — performance_speed finding category)
# ---------------------------------------------------------------------------
# Generate a free key at https://console.cloud.google.com/apis/credentials.
# Used by scripts/ai_audit/performance_speed.py. Without it, the
# performance-speed finding category is skipped silently.
PSI_API_KEY=

# ---------------------------------------------------------------------------
# GitHub — DORMANT (auto-create-issues feature pulled May 2026)
# ---------------------------------------------------------------------------
# scripts/github_integration.py and scripts/github_push.py remain in the repo
# as dormant code. The Pro-tier "we'll create one issue per finding" promise
# was removed from landing pricing pages and the post-purchase email branch.
# If you ever re-enable, uncomment the line below and add a Personal Access
# Token with `repo` scope from https://github.com/settings/tokens.
# GITHUB_PAT=

# ---------------------------------------------------------------------------
# Playwright (BL-14 — gated on customer 10)
# ---------------------------------------------------------------------------
HEADLESS=true
